# Resend (email service)
RESEND_API_KEY=""

# Uploadthing
UPLOADTHING_SECRET=""

# Supabase (alternative database/auth)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
