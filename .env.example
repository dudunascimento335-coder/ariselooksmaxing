# Environment Variables

# Database
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# App
APP_URL="http://localhost:3000"

# OpenAI (optional - analysis uses mock without it)
